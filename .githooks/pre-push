#!/bin/bash

# Blocks direct pushes to main — all changes must go through a branch + PR.

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$current_branch" = "main" ]; then
    echo ""
    echo -e "${RED}[ERROR]${NC} Direct pushes to main are not allowed."
    echo ""
    echo "  Create a branch, push it, and open a PR instead:"
    echo ""
    echo "    git checkout -b your-feature-name"
    echo "    git push -u origin your-feature-name"
    echo ""
    exit 1
fi

echo -e "${GREEN}[OK]${NC} Pushing branch '$current_branch'."
exit 0
